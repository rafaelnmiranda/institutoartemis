# SMTP — servidor de e-mail (ex.: Gmail / Google Workspace com App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Destino das mensagens do formulário de contato
CONTACT_TO=

# Credenciais do painel administrativo (defina valores fortes em produção)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel Blob — uploads de imagens e PDFs em produção
# Crie um Blob store no dashboard Vercel; o token pode ser injetado automaticamente
BLOB_READ_WRITE_TOKEN=
